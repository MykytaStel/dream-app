<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/last_dream_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/dream_widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/dream_last_dream_widget_label"
        android:textAllCaps="true"
        android:textColor="#6B6256"
        android:textSize="10sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/last_dream_title"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="10dp"
        android:maxLines="4"
        android:textColor="#1E2324"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>
